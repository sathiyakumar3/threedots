{
  "firestore": {
    "database": "(default)",
    "location": "australia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "threedots",
        "supportEmail": "support@threedots.app"
      }
    },
    "email": {
      "senderDisplayName": "Taskbz",
      "senderLocalPart": "noreply",
      "customDomain": "threedots.app",
      "actionUrl": "https://threedots.app/__/auth/action"
    }
  }
}
